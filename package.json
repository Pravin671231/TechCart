{
  "name": "techcart",
  "version": "0.1.0",
  "private": true,
  "description": "TechCart — Node/Express API with a Next.js buyer storefront and a React/Vite admin console",
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "eslint .",
    "test": "npm run test --workspaces",
    "test:backend": "npm run test --workspace backend",
    "test:buyer-app": "npm run test --workspace buyer-app",
    "test:admin-app": "npm run test --workspace admin-app"
  },
  "workspaces": [
    "backend",
    "buyer-app",
    "admin-app"
  ],
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "postcss": "^8.5.21",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "jiti": "^2.7.0",
    "prettier": "^3.9.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
